{
  "name": "example",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --restart-tries=1 --prefix-colors='white.bold.bgCyan,white.bold.bgYellow,white.bold.bgGreen' --prefix=' {name} ' --names='VITE,CONVEX,CONFECT' 'vite' 'convex dev --tail-logs' 'confect dev'",
    "convex-codegen": "convex codegen",
    "typecheck": "tsc --noEmit --project tsconfig.json && tsc --noEmit --project convex/tsconfig.json",
    "build": "vite build --mode development",
    "format": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "fix": "prettier --write . && eslint --fix . --max-warnings=0",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@confect/cli": "catalog:",
    "@confect/core": "catalog:",
    "@confect/react": "catalog:",
    "@confect/server": "catalog:",
    "@convex-dev/workflow": "catalog:",
    "@convex-dev/workpool": "catalog:",
    "confect-workflow": "workspace:*",
    "@effect/platform": "catalog:",
    "convex": "catalog:",
    "effect": "catalog:",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "vite": "^8.0.1"
  },
  "devDependencies": {
    "@confect/test": "catalog:",
    "@effect/vitest": "catalog:",
    "@eslint/js": "10.0.1",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "9.2.1",
    "eslint": "10.0.3",
    "npmx-connector": "^0.4.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.1"
  }
}
